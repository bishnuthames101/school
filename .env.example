# ==============================================================================
# SCHOOL PLATFORM — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in all values before running the app.
# Each Vercel deployment (one per school) gets its own copy of these vars.
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE (Supabase PostgreSQL)
# Both URLs point to the same database — Prisma uses DATABASE_URL for queries
# (via pgBouncer connection pooler) and DIRECT_URL only for migrations.
# Find these in: Supabase Dashboard → Project Settings → Database → Connection string
# ------------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-northeast-1.supabase.com:5432/postgres"

# ------------------------------------------------------------------------------
# SUPABASE STORAGE
# Used by lib/storage.ts to upload images and documents.
# NEXT_PUBLIC_SUPABASE_URL: Supabase Dashboard → Project Settings → API → Project URL
# SUPABASE_SERVICE_ROLE_KEY: Supabase Dashboard → Project Settings → API → service_role key
# WARNING: SUPABASE_SERVICE_ROLE_KEY is secret — never expose it to the browser.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGci..."

# ------------------------------------------------------------------------------
# AUTHENTICATION
# JWT_SECRET: A long random string used to sign admin session tokens.
# Generate one with: openssl rand -base64 32
#
# ADMIN_PASSWORD_HASH: bcrypt hash of the admin password stored in the DB.
# This is used by lib/auth.ts to verify login. Generate with:
#   node -e "const b=require('bcryptjs'); b.hash('yourpassword',10).then(console.log)"
# ------------------------------------------------------------------------------
JWT_SECRET="replace-with-a-long-random-secret-min-32-chars"
ADMIN_PASSWORD_HASH="$2b$10$..."

# ------------------------------------------------------------------------------
# SCHOOL IDENTITY
# SCHOOL_ID selects which school config to load from schools/{slug}/config.ts
# and scopes all database queries to that school.
# NEXT_PUBLIC_SCHOOL_ID must match SCHOOL_ID — it is the client-side equivalent.
# Example: kopess, schoolb, greenvalley
# ------------------------------------------------------------------------------
SCHOOL_ID="kopess"
NEXT_PUBLIC_SCHOOL_ID="kopess"

# ------------------------------------------------------------------------------
# EMAIL NOTIFICATIONS (Resend)
# RESEND_API_KEY: Resend Dashboard → API Keys
# RESEND_FROM_EMAIL: Must be a verified sender domain in Resend (e.g. noreply@yourdomain.com)
# ADMIN_NOTIFICATION_EMAIL: Where to send new application and contact form alerts.
# If RESEND_API_KEY is not set, email notifications are silently skipped.
# ------------------------------------------------------------------------------
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@yourdomain.com"
ADMIN_NOTIFICATION_EMAIL="admin@yourschool.edu.np"

# ------------------------------------------------------------------------------
# WHATSAPP NOTIFICATIONS (Fonnte)
# Used by POST /api/notifications/send to send WhatsApp messages to parents.
# Fonnte Dashboard: https://fonnte.com
# If not configured, the notification send endpoint returns a 500 with a clear message.
# Phone numbers must be stored in international format: 977XXXXXXXXXX (Nepal)
# ------------------------------------------------------------------------------
FONNTE_API_KEY="your_fonnte_api_key"

# ==============================================================================
# SCRIPTS ONLY (not needed by the running app)
# These are only used when running scripts/create-school-admin.ts or
# scripts/reset-admin-password.ts locally. Never set these in Vercel.
# ==============================================================================
# ADMIN_USERNAME="admin"
# ADMIN_PASSWORD="set-a-strong-password"
